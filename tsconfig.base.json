{
  "compilerOptions": {
    // Base options
    "target": "es2022",
    "moduleDetection": "force",
    "verbatimModuleSyntax": true,
    "skipLibCheck": true,
    "allowJs": true,
    "resolveJsonModule": true,
    "esModuleInterop": true,
    "isolatedModules": true,

    // Strictness
    "strict": true,
    "noImplicitOverride": true,
    "noUncheckedIndexedAccess": true,

    // Monorepo
    "composite": true,

    // Bundling
    "sourceMap": true,
    "declaration": true,
    "declarationMap": true,
    "noEmit": true,
    "module": "preserve",
    "outDir": "./dist",

    // Paths
    "rootDirs": ["src", "tests"],
    "paths": {
      "@/*": ["src/*"],
      "@tests/*": ["tests/*"]
    }
  }
}
