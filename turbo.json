{
  "$schema": "https://turborepo.dev/schema.json",
  "ui": "tui",
  "tasks": {
    // packages
    "prepare": {
      "dependsOn": ["^prepare"],
      "outputs": ["dist/**/*"]
    },
    "check": {
      "dependsOn": ["^prepare", "^check"]
    },
    "test": {
      "dependsOn": ["^prepare"],
      "persistent": true,
      "cache": false
    },
    // apps
    "dev": {
      "dependsOn": ["^prepare"],
      "persistent": true,
      "cache": false
    },
    "build": {
      "dependsOn": ["^prepare", "build"],
      "outputs": ["dist/**/*"]
    },
    "serve": {
      "dependsOn": ["^prepare", "build"]
    }
  }
}
