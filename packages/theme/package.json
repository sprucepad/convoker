{
  "name": "@convoker/theme",
  "type": "module",
  "version": "0.1.1",
  "description": "A simple CLI theming library.",
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    },
    "./global": {
      "types": "./dist/global.d.mts",
      "import": "./dist/global.mjs",
      "require": "./dist/global.cjs"
    },
    "./utils": {
      "types": "./dist/utils.d.mts",
      "import": "./dist/utils.mjs",
      "require": "./dist/utils.cjs"
    }
  },
  "scripts": {
    "test": "vitest",
    "prepare": "tsdown",
    "check": "tsc"
  },
  "keywords": [
    "convoker",
    "theme",
    "theming"
  ],
  "files": [
    "src",
    "dist"
  ],
  "author": "sprucepad",
  "license": "MIT",
  "packageManager": "pnpm@10.30.3",
  "publishConfig": {
    "access": "public"
  }
}
