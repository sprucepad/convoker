{
  "name": "@convoker/core",
  "version": "0.4.1",
  "description": "A simple, type-safe CLI argument parser for TypeScript.",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/convoker/convoker.js"
  },
  "main": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs"
    },
    "./command": {
      "types": "./dist/command/index.d.mts",
      "import": "./dist/command/index.mjs"
    },
    "./theme": {
      "types": "./dist/theme.d.mts",
      "import": "./dist/theme.mjs"
    },
    "./input": {
      "types": "./dist/input/index.d.mts",
      "import": "./dist/input/index.mjs"
    },
    "./color": {
      "types": "./dist/color/index.d.mts",
      "import": "./dist/color/index.mjs"
    },
    "./prompt": {
      "types": "./dist/prompt/index.d.mts",
      "import": "./dist/prompt/index.mjs"
    },
    "./prompt/raw": {
      "types": "./dist/prompt/raw.d.mts",
      "import": "./dist/prompt/raw.mjs"
    }
  },
  "type": "module",
  "scripts": {
    "test": "vitest",
    "prepare": "tsdown",
    "check": "tsc"
  },
  "files": [
    "dist"
  ],
  "keywords": [
    "cli",
    "command",
    "args",
    "argv",
    "option"
  ],
  "author": "sprucepad",
  "license": "MIT",
  "packageManager": "pnpm@10.30.3"
}
