{
  "name": "@convoker/prompt",
  "version": "0.2.0",
  "description": "A simple, type-safe CLI prompting library.",
  "exports": {
    ".": {
      "types": "./dist/prompts/index.d.mts",
      "import": "./dist/prompts/index.mjs",
      "require": "./dist/prompts/index.cjs"
    },
    "./core": {
      "types": "./dist/core/index.d.mts",
      "import": "./dist/core/index.mjs",
      "require": "./dist/core/index.cjs"
    }
  },
  "scripts": {
    "test": "vitest",
    "prepare": "tsdown",
    "check": "tsc"
  },
  "keywords": [
    "convoker",
    "prompt"
  ],
  "dependencies": {
    "@convoker/input": "workspace:*",
    "@convoker/theme": "workspace:*",
    "rxjs": "^7.8.2"
  },
  "files": [
    "src",
    "dist"
  ],
  "author": "sprucepad",
  "license": "MIT",
  "packageManager": "pnpm@10.30.3",
  "publishConfig": {
    "access": "public"
  }
}
